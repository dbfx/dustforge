{
  "name": "dustforge",
  "version": "1.9.0",
  "description": "A modern, open-source system cleaner for Windows",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder",
    "test": "vitest run",
    "test:watch": "vitest",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "release": "node -e \"const v='v'+require('./package.json').version;const{execSync:r}=require('child_process');r('git tag '+v,{stdio:'inherit'});r('git push origin '+v,{stdio:'inherit'});console.log('\\nTag '+v+' pushed. GitHub CI will build and publish the release.\\nTrack progress: https://github.com/dbfx/dustforge/actions/workflows/release.yml')\"",
    "prepare": "husky"
  },
  "keywords": [
    "system-cleaner",
    "electron",
    "windows",
    "optimization"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "conventional-changelog-cli": "^5.0.0",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "husky": "^9.1.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.35.1",
    "lucide-react": "^0.577.0",
    "pusher-js": "^8.4.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0",
    "sonner": "^2.0.7",
    "systeminformation": "^5.31.3",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.11"
  }
}
